{
    "name": "ai-se-tool",
    "displayName": "AI SE Tool",
    "description": "AI-Powered Software Engineering Intelligence Tool",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Other"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "ai-se-tool.analyzeCode",
                "title": "AI SE: Analyze Code"
            },
            {
                "command": "ai-se-tool.debugCode",
                "title": "AI SE: Debug Code"
            },
            {
                "command": "ai-se-tool.generateTests",
                "title": "AI SE: Generate Tests"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/vscode": "^1.70.0",
        "@types/node": "^16.11.7",
        "typescript": "^4.7.4"
    },
    "dependencies": {
        "axios": "^1.6.0"
    }
}